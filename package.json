{
  "name": "youtube-private-invitations",
  "version": "1.0.0",
  "description": "Browser extension to quickly invite emails to private YouTube videos",
  "keywords": [
    "browser-extension",
    "youtube",
    "youtube-studio"
  ],
  "license": "MIT",
  "author": {
    "name": "Karl Horky",
    "email": "karl.horky@gmail.com"
  },
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "dev": "wxt",
    "lint": "eslint . --max-warnings 0",
    "tsc-check": "tsc --noEmit",
    "zip": "wxt zip"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/chrome": "0.2.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/module-react": "1.2.2",
    "eslint": "10.6.0",
    "eslint-config-upleveled": "10.0.0",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "wxt": "0.20.27"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
      "onFail": "download"
    }
  }
}
